# MacroFactor credentials (required)
MACROFACTOR_USERNAME=your@email.com
MACROFACTOR_PASSWORD=your-password

# Firebase & Typesense keys (from app — required for API access)
FIREBASE_WEB_API_KEY=
TYPESENSE_HOST=
TYPESENSE_API_KEY=

# Local HTTP MCP server
HOST=127.0.0.1
PORT=3001
MCP_AUTH_TOKEN=generate-with-openssl-rand-hex-32

# Claude.ai connector proxy
MACROFACTOR_CONNECTOR_PUBLIC_BASE_URL=https://your-mac.your-tailnet.ts.net
MACROFACTOR_CONNECTOR_PUBLIC_PATH=/macrofactor
MACROFACTOR_CONNECTOR_RESOURCE_PATH=/macrofactor/mcp
MACROFACTOR_CONNECTOR_LOGIN_SECRET=generate-a-long-login-secret
MACROFACTOR_CONNECTOR_TOKEN_SECRET=generate-with-openssl-rand-hex-32
MACROFACTOR_CONNECTOR_HOST=127.0.0.1
MACROFACTOR_CONNECTOR_PORT=3010
MACROFACTOR_MCP_UPSTREAM_URL=http://127.0.0.1:3001/mcp
MACROFACTOR_MCP_UPSTREAM_TOKEN=generate-with-openssl-rand-hex-32
